{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/**": {
      "maxDuration": 15,
      "includeFiles": "migrations/**"
    }
  },
  "rewrites": [
    { "source": "/health", "destination": "/api/health" }
  ],
  "crons": [
    {
      "path": "/api/cron/expire",
      "schedule": "*/10 * * * *"
    }
  ]
}
