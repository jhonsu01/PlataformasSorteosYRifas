{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/index.js": {
      "maxDuration": 15,
      "includeFiles": "migrations/**"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index?__path=/$1" }
  ],
  "crons": [
    {
      "path": "/api/cron/expire",
      "schedule": "0 4 * * *"
    }
  ]
}
