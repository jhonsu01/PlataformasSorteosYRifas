# =========================================================================
# Variables de entorno (referencia). Copia a .env y completa. NUNCA commitear .env.
# =========================================================================

# --- Backend ---
# Si esta vacia, el backend usa el store en MEMORIA (demo, se pierde al reiniciar).
# En produccion usa la cadena con pooling de Neon/Vercel Postgres.
DATABASE_URL=postgres://usuario:password@host:5432/db
PG_POOL_MAX=3                         # pool pequeno en serverless (Vercel)
# PGSSL_NO_VERIFY=true                # solo si tu proveedor usa certificado self-signed
RESERVE_MINUTES=15                    # minutos que un numero queda reservado
CRON_SECRET=cambia-esto               # protege /api/cron/expire (Vercel Cron)

# --- Rate limiting (0 = desactivado) ---
# Se cuenta por IP en la base (en serverless un contador en memoria no sirve).
# OJO: el movil colombiano sale por CGNAT y varios compradores COMPARTEN IP;
# por eso los limites son holgados. Si los bajas mucho, bloquearas gente real.
RATE_LIMIT_RESERVE=15                 # reservas por IP cada 10 min (evita bloquear la rifa)
RATE_LIMIT_LOGIN=10                   # intentos de login por IP cada 10 min (fuerza bruta)
RATE_LIMIT_WEBHOOK=120                # eventos por IP por minuto (Wompi reintenta: no lo bajes)
# SEED_DEMO=true                      # siembra la rifa demo (por defecto: solo sin DATABASE_URL)

# --- Sesiones (OBLIGATORIO en produccion) ---
# Sin JWT_ACCESS_SECRET el backend NO arranca si hay DATABASE_URL: en serverless
# cada contenedor generaria un secreto distinto y las sesiones se caerian al azar.
# Genera uno con:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET=cambia-esto
JWT_ACCESS_TTL=900                    # segundos del token de acceso (15 min)
JWT_REFRESH_TTL=2592000               # segundos del refresh (30 dias)

# --- Wompi (Colombia / COP) ---
# Wompi entrega 4 valores distintos. NO los confundas: cada uno va en su sitio.
#
#   Llave publica         pub_test_...        -> WOMPI_PUBLIC_KEY      (se expone, es publica)
#   Secreto de integridad test_integrity_...  -> WOMPI_INTEGRITY_SECRET (firma el checkout)
#   Secreto de eventos    test_events_...     -> WOMPI_EVENTS_KEY      (valida el webhook)
#   Llave privada         prv_test_...        -> NO se usa aqui (es para la API REST de Wompi)
#
WOMPI_ENV=test                        # SOLO "test" o "prod". Nunca pegues un secreto aqui.
WOMPI_PUBLIC_KEY=pub_test_xxx
WOMPI_INTEGRITY_SECRET=test_integrity_xxx
WOMPI_EVENTS_KEY=test_events_xxx
# WOMPI_PRIVATE_KEY=                  # alias antiguo de WOMPI_INTEGRITY_SECRET (compatibilidad)

# --- GitHub (publicacion del estado publico de rifas) ---
# Opcional: sin esto el backend sigue sirviendo el JSON por su API, pero el
# sorteo no queda auditable en un repo publico (Guia 8).
#
# Recomendado: una ORGANIZACION dedicada + PAT fine-grained con Resource owner =
# esa org, Contents:write y Administration:write (para crear los repos). Asi un
# token filtrado solo alcanza los repos de rifas, nunca tus otros proyectos.
# OJO: el nombre es GITHUB_RIFFLES_TOKEN, NO GITHUB_TOKEN. En Vercel se comprobo
# que GITHUB_TOKEN no llega a la funcion (la plataforma trata ese nombre aparte).
GITHUB_RIFFLES_TOKEN=                  # PAT fine-grained
GITHUB_RIFFLES_OWNER=mi-org-de-sorteos # organizacion (o usuario) dueño de los repos
GITHUB_RIFFLES_BRANCH=main
# GITHUB_RIFFLES_ORG=                  # alias antiguo de GITHUB_RIFFLES_OWNER

# --- App / Web ---
NEXT_PUBLIC_WEB_URL=https://sorteo.vercel.app
NEXT_PUBLIC_GITHUB_RAW_BASE=https://raw.githubusercontent.com/jhonsu01/PlataformasSorteosYRifas/main/examples/sorteo-demo/public

# --- Firma del APK (usada por GitHub Actions como secretos del repo) ---
# ANDROID_KEYSTORE_BASE64=...          # base64 del keystore .jks
# ANDROID_KEYSTORE_PASSWORD=...
# ANDROID_KEY_ALIAS=sorteos
# ANDROID_KEY_PASSWORD=...
