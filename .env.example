# =========================================================================
# Variables de entorno (referencia). Copia a .env y completa. NUNCA commitear .env.
# =========================================================================

# --- Backend ---
# Si esta vacia, el backend usa el store en MEMORIA (demo, se pierde al reiniciar).
# En produccion usa la cadena con pooling de Neon/Vercel Postgres.
DATABASE_URL=postgres://usuario:password@host:5432/db
PG_POOL_MAX=3                         # pool pequeno en serverless (Vercel)
# PGSSL_NO_VERIFY=true                # solo si tu proveedor usa certificado self-signed
RESERVE_MINUTES=15                    # minutos que un numero queda reservado
CRON_SECRET=cambia-esto               # protege /api/cron/expire (Vercel Cron)
# SEED_DEMO=true                      # siembra la rifa demo (por defecto: solo sin DATABASE_URL)

# --- Sesiones (OBLIGATORIO en produccion) ---
# Sin JWT_ACCESS_SECRET el backend NO arranca si hay DATABASE_URL: en serverless
# cada contenedor generaria un secreto distinto y las sesiones se caerian al azar.
# Genera uno con:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET=cambia-esto
JWT_ACCESS_TTL=900                    # segundos del token de acceso (15 min)
JWT_REFRESH_TTL=2592000               # segundos del refresh (30 dias)

# --- Wompi (Colombia / COP) ---
WOMPI_PUBLIC_KEY=pub_test_xxx
WOMPI_PRIVATE_KEY=prv_test_xxx        # firma de integridad (solo servidor)
WOMPI_EVENTS_KEY=evt_xxx              # verificacion de webhooks
WOMPI_ENV=test                        # test | prod
WOMPI_WEBHOOK_SECRET=cambia-esto

# --- GitHub (publicacion del estado publico de rifas) ---
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=                    # o GITHUB_TOKEN fine-grained
GITHUB_RIFFLES_ORG=mi-org             # repos de rifas: <org>/sorteo-*

# --- App / Web ---
NEXT_PUBLIC_WEB_URL=https://sorteo.vercel.app
NEXT_PUBLIC_GITHUB_RAW_BASE=https://raw.githubusercontent.com/jhonsu01/PlataformasSorteosYRifas/main/examples/sorteo-demo/public

# --- Firma del APK (usada por GitHub Actions como secretos del repo) ---
# ANDROID_KEYSTORE_BASE64=...          # base64 del keystore .jks
# ANDROID_KEYSTORE_PASSWORD=...
# ANDROID_KEY_ALIAS=sorteos
# ANDROID_KEY_PASSWORD=...
