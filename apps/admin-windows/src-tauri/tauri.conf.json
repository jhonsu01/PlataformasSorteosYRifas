{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sorteos y Rifas Admin",
  "version": "1.0.0",
  "identifier": "com.sorteosyrifas.admin",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Sorteos y Rifas — Administración",
        "width": 1100,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "publisher": "Sorteos y Rifas",
    "category": "Business",
    "shortDescription": "Administrador de sorteos y rifas",
    "longDescription": "Aplicación de escritorio para configurar rifas, aprobar comprobantes y declarar ganadores. Parte del framework abierto de Sorteos y Rifas.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
